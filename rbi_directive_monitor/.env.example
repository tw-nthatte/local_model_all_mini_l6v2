# RBI Master Directives Monitor - Configuration File
# Copy this to .env and fill in your configuration

# Application Settings
APP_ENV=development
DEBUG=false

# Database Configuration
# For SQLite (default):
DATABASE_URL=sqlite:///./rbi_monitor.db
# For PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/rbi_monitor

# Scraper Configuration
RBI_MASTER_DIRECTIVES_URL=https://www.rbi.org.in/scripts/BS_ViewMasterDirections.aspx
REQUEST_TIMEOUT=30
SCRAPE_INTERVAL_HOURS=24
ENABLE_SCHEDULER=true

# Classification Configuration
SIMILARITY_THRESHOLD=0.3
MIN_KEYWORD_MATCHES=2
KEYWORDS_FILE=data/keywords.json

# PDF Storage Configuration
PDF_STORAGE_PATH=data/pdfs
MAX_PDF_SIZE_MB=50

# Email Notification Configuration
# Gmail Example:
# 1. Enable 2-factor authentication
# 2. Generate app password: https://myaccount.google.com/apppasswords
# 3. Use app password in SMTP_PASSWORD
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
ALERT_EMAIL=your-email@company.com

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/rbi_monitor.log
